{
  "manifest_version": 3,
  "name": "Safari Window Naming & Switcher",
  "version": "0.2.0",
  "description": "Assign custom names to Safari windows, quickly filter, and switch between windows effortlessly.",
  "author": "Nick Lee <coolnickldd@gmail.com>",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Window Switcher",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "options/options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Alt+O",
        "mac": "MacCtrl+Alt+O"
      },
      "description": "Open Window Switcher & Rename Panel"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  }
}
